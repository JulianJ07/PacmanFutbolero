class Rival {
   field Board board;
   field int row;
   field int col;
   field int direction;
   field boolean active;
   field boolean leavingCage;
   field int releaseDelay;
   field int straightSteps;
   field int blockedRow;
   field int blockedCol;
   field int blockedHits;

   constructor Rival new(Board gameBoard, int startRow, int startCol, int startDirection) {
      let board = gameBoard;
      let row = startRow;
      let col = startCol;
      let direction = startDirection;
      let active = false;
      let leavingCage = true;
      let releaseDelay = 0;
      let straightSteps = 0;
      let blockedRow = -1;
      let blockedCol = -1;
      let blockedHits = 0;
      return this;
   }

   method int getRow() {
      return row;
   }

   method int getCol() {
      return col;
   }

   method boolean isActive() {
      return active;
   }

   method boolean isResting() {
      return releaseDelay > 0;
   }

   method void release() {
      if (~active) {
         let active = true;
         let leavingCage = false;
         let releaseDelay = 0;
      }
      return;
   }

   method boolean isInCage() {
      if ((row > 7) & (row < 12) & (col > 12) & (col < 18)) {
         return true;
      }
      if ((row = 8) & (col = 15)) {
         return true;
      }
      return false;
   }

   method void leaveCage() {
      var int nextRow;
      var int nextCol;

      let nextRow = row;
      let nextCol = col;

      if (col < 15) {
         let nextCol = col + 1;
      } else {
         if (col > 15) {
            let nextCol = col - 1;
         } else {
            let nextRow = row - 1;
         }
      }

      if (board.canEnter(nextRow, nextCol)) {
         do board.drawCell(row, col);
         let row = nextRow;
         let col = nextCol;
         do draw();
      }

      if (~isInCage()) {
         let leavingCage = false;
      }

      return;
   }

   method void moveStep(int targetRow, int targetCol) {
      var boolean moved;

      if (~active) {
         return;
      }

      if (releaseDelay > 0) {
         let releaseDelay = releaseDelay - 1;
         if (releaseDelay = 0) {
            do board.drawCell(row, col);
         }
         do draw();
         return;
      }

      if (leavingCage) {
         do leaveCage();
         return;
      }

      let straightSteps = straightSteps + 1;
      if (straightSteps < 3) {
         return;
      }
      let straightSteps = 0;

      let moved = false;

      if (blockedHits > 3) {
         let moved = tryEscapeMove();
      }

      if ((targetCol > col) & (~moved)) {
         let moved = tryChasing(row, col + 1, 0);
      }

      if ((targetCol < col) & (~moved)) {
         let moved = tryChasing(row, col - 1, 2);
      }

      if ((targetRow > row) & (~moved)) {
         let moved = tryChasing(row + 1, col, 1);
      }

      if ((targetRow < row) & (~moved)) {
         let moved = tryChasing(row - 1, col, 3);
      }

      if (~moved) {
         let moved = tryMove(row, col + 1);
      }
      if (~moved) {
         let moved = tryMove(row, col - 1);
      }
      if (~moved) {
         let moved = tryMove(row + 1, col);
      }
      if (~moved) {
         let moved = tryMove(row - 1, col);
      }

      if (~moved) {
         do draw();
      }

      return;
   }

   method boolean tryChasing(int nextRow, int nextCol, int nextDirection) {
      if (board.canEnter(nextRow, nextCol)) {
         let direction = nextDirection;
         let blockedHits = 0;
         return tryMove(nextRow, nextCol);
      }

      do rememberBlockedCell(nextRow, nextCol, nextDirection);
      return false;
   }

   method void rememberBlockedCell(int nextRow, int nextCol, int nextDirection) {
      if ((blockedRow = nextRow) & (blockedCol = nextCol)) {
         let blockedHits = blockedHits + 1;
      } else {
         let blockedRow = nextRow;
         let blockedCol = nextCol;
         let blockedHits = 1;
      }

      if (blockedHits > 3) {
         let direction = nextDirection + 1;
         if (direction > 3) {
            let direction = 0;
         }
      }

      return;
   }

   method boolean tryEscapeMove() {
      var int tries;
      var boolean moved;

      let tries = 0;
      let moved = false;

      while ((tries < 4) & (~moved)) {
         if (direction = 0) {
            let moved = tryMove(row, col + 1);
         }
         if ((direction = 1) & (~moved)) {
            let moved = tryMove(row + 1, col);
         }
         if ((direction = 2) & (~moved)) {
            let moved = tryMove(row, col - 1);
         }
         if ((direction = 3) & (~moved)) {
            let moved = tryMove(row - 1, col);
         }

         if (~moved) {
            let direction = direction + 1;
            if (direction > 3) {
               let direction = 0;
            }
         }

         let tries = tries + 1;
      }

      if (moved) {
         let blockedHits = 0;
      }

      return moved;
   }

   method boolean tryMove(int nextRow, int nextCol) {
      if (board.canEnter(nextRow, nextCol)) {
         do board.drawCell(row, col);
         let row = nextRow;
         let col = nextCol;
         do draw();
         return true;
      }

      return false;
   }

   method void resetHome() {
      do board.drawCell(row, col);
      let row = 10;
      let col = 15;
      let leavingCage = true;
      let releaseDelay = 90;
      let straightSteps = 0;
      let blockedHits = 0;
      let active = true;
      do board.drawCell(row, col);
      do draw();
      return;
   }

   method void draw() {
      var int x;
      var int y;

      let x = board.xOf(col);
      let y = board.yOf(row);

      if (releaseDelay > 0) {
         do drawResting();
         return;
      }

      do Screen.setColor(false);
      do Screen.drawRectangle(x + 3, y + 1, x + 6, y + 2);
      do Screen.drawRectangle(x + 2, y + 3, x + 7, y + 7);
      do Screen.drawRectangle(x + 1, y + 4, x + 8, y + 5);
      do Screen.drawRectangle(x + 2, y + 8, x + 3, y + 8);
      do Screen.drawRectangle(x + 6, y + 8, x + 7, y + 8);
      do Screen.setColor(true);
      do Screen.drawRectangle(x + 3, y + 3, x + 3, y + 7);
      do Screen.drawRectangle(x + 6, y + 3, x + 6, y + 7);
      do Screen.drawRectangle(x + 4, y + 6, x + 5, y + 6);
      do Screen.drawRectangle(x + 4, y + 2, x + 4, y + 2);
      do Screen.drawRectangle(x + 6, y + 2, x + 6, y + 2);

      return;
   }

   method void drawResting() {
      var int x;
      var int y;

      let x = board.xOf(col);
      let y = board.yOf(row);

      do Screen.setColor(false);
      do Screen.drawRectangle(x + 2, y + 3, x + 7, y + 7);
      do Screen.drawRectangle(x + 3, y + 2, x + 6, y + 2);
      do Screen.drawRectangle(x + 3, y + 8, x + 6, y + 8);
      do Screen.setColor(true);
      do Screen.drawRectangle(x + 3, y + 4, x + 6, y + 4);
      do Screen.drawRectangle(x + 4, y + 6, x + 5, y + 6);
      do Screen.drawRectangle(x + 7, y + 1, x + 8, y + 1);
      do Screen.drawRectangle(x + 8, y + 0, x + 8, y + 0);

      return;
   }

   method void dispose() {
      do Memory.deAlloc(this);
      return;
   }
}
